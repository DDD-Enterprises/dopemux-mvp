{
  "mcpServers": {
    "zen": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-zen",
        "bash",
        "-c",
        "source /app/.venv/bin/activate && python3 server.py"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY:-}",
        "GEMINI_API_KEY": "${GEMINI_API_KEY:-REDACTED_SECRET}",
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY:-REDACTED_SECRET}",
        "XAI_API_KEY": "${XAI_API_KEY:-REDACTED_SECRET}",
        "DISABLED_TOOLS": "refactor,testgen,secaudit,docgen,tracer",
        "DEFAULT_MODEL": "auto"
      }
    },
    "conport": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-conport",
        "python3",
        "/app/enhanced_server.py"
      ],
      "env": {
        "WORKSPACE_ID": "/Users/hue/code/dopemux-mvp",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "VOYAGEAI_API_KEY": "${VOYAGEAI_API_KEY}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      }
    },
    "serena-v2": {
      "type": "sse",
      "url": "http://localhost:3006/sse",
      "env": {
        "WORKSPACE_ID": "/Users/hue/code/dopemux-mvp"
      }
    },
    "gpt-researcher": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-gptr-mcp",
        "python",
        "/app/gptr-mcp/server.py"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "exa": {
      "type": "stdio",
      "command": "/Users/hue/code/dopemux-mvp/docker/mcp-servers/exa/start_with_uvx.sh",
      "args": [],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "description": "Neural web search with native uvx support (no Docker)"
    },
    "dope-context": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "/Users/hue/code/dopemux-mvp/services/dope-context/run_mcp.sh"
      ],
      "env": {
        "VOYAGE_API_KEY": "${VOYAGEAI_API_KEY}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@context7/mcp-server"
      ]
    },
    "desktop-commander": {
      "type": "stdio",
      "command": "/Users/hue/code/dopemux-mvp/docker/mcp-servers/desktop-commander/start_with_uvx.sh",
      "args": [],
      "env": {},
      "description": "Desktop automation with native macOS support (uvx-based)"
    }
  }
}
