{
  "mcpServers": {
    "dopemux-pal": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/Users/hue/code/dopemux-mvp/docker/mcp-servers/pal/pal-mcp-server",
        "python",
        "server.py"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY:-}",
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY:-}",
        "GEMINI_API_KEY": "${GEMINI_API_KEY:-}",
        "XAI_API_KEY": "${XAI_API_KEY:-}",
        "DISABLED_TOOLS": "refactor,testgen,secaudit,docgen,tracer",
        "DEFAULT_MODEL": "auto",
        "PAL_DEFAULT_PROVIDER": "openrouter"
      }
    },
    "dopemux-conport": {
      "type": "sse",
      "url": "http://localhost:3004/sse",
      "env": {
        "WORKSPACE_ID": "/Users/hue/code/dopemux-mvp",
        "GEMINI_API_KEY": "${GEMINI_API_KEY:-}",
        "VOYAGEAI_API_KEY": "${VOYAGEAI_API_KEY:-}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY:-}"
      }
    },
    "dopemux-serena": {
      "type": "sse",
      "url": "http://localhost:3006/sse",
      "env": {
        "WORKSPACE_ID": "/Users/hue/code/dopemux-mvp"
      }
    },
    "dopemux-gpt-researcher": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "dopemux-mcp-gptr-mcp",
        "python",
        "/app/server.py"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY:-}",
        "TAVILY_API_KEY": "${TAVILY_API_KEY:-}",
        "EXA_API_KEY": "${EXA_API_KEY:-}",
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY:-}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY:-}"
      },
      "description": "Deep research with comprehensive analysis using Docker container"
    },
    "dopemux-exa": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-litellm",
        "python",
        "/app/exa_server.py"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY:-}"
      },
      "description": "Neural web search via Docker container"
    },
    "dopemux-claude-context": {
      "type": "sse",
      "url": "http://localhost:3010/mcp",
      "env": {
        "VOYAGE_API_KEY": "${VOYAGEAI_API_KEY:-}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY:-}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY:-}"
      }
    },
    "dopemux-desktop-commander": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "dopemux-mcp-desktop-commander",
        "python",
        "/app/mcp_server.py"
      ],
      "env": {
        "DISPLAY": "${DISPLAY:-:0}"
      },
      "description": "Desktop automation via Docker container"
    },
    "task-orchestrator": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/Users/hue/code/dopemux-mvp/services/task-orchestrator/task_orchestrator/app.py"
      ],
      "env": {
        "WORKSPACE_ID": "/Users/hue/code/dopemux-mvp",
        "PYTHONPATH": "/Users/hue/code/dopemux-mvp/services/task-orchestrator"
      },
      "description": "Advanced task orchestration and dependency management"
    }
  }
}