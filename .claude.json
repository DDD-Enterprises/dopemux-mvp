{
  "mcpServers": {
    "zen": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-zen",
        "bash",
        "-c",
        "source /app/.venv/bin/activate && python zen-mcp-server/server.py"
      ],
      "env": {
        "OPENAI_API_KEY": "",  // Disabled - no direct OpenAI calls
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY:-}",
        "GEMINI_API_KEY": "${GEMINI_API_KEY:-AIzaSyCkYsYc73ouBiRw8nryattIKzEI_qP5UEw}",
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY:-AIzaSyCkYsYc73ouBiRw8nryattIKzEI_qP5UEw}",
        "XAI_API_KEY": "${XAI_API_KEY:-xai-ZkmIhVJxh5MbOVzKwRecajBn5O7Jdr1NWuK8u7xtVi93hi6ESaprl7D4itYrgCoebO7mUBknKToAtcEt}",
        "DISABLED_TOOLS": "refactor,testgen,secaudit,docgen,tracer",
        "DEFAULT_MODEL": "auto",
        "ZEN_DEFAULT_PROVIDER": "openrouter"  // Prefer OpenRouter for routing
      }
    },
    "conport": {
      "type": "sse",
      "url": "http://localhost:3004/sse",
      "env": {
        "WORKSPACE_ID": "/Users/hue/code/dopemux-mvp",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "VOYAGEAI_API_KEY": "${VOYAGEAI_API_KEY}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      }
    },
    "serena-v2": {
      "type": "sse",
      "url": "http://localhost:3006/sse",
      "env": {
        "WORKSPACE_ID": "/Users/hue/code/dopemux-mvp"
      }
    },
    "gpt-researcher": {
      "type": "sse",
      "url": "http://localhost:3009/sse",
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "EXA_API_KEY": "${EXA_API_KEY}",
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      },
      "description": "Deep research with comprehensive analysis via container"
    },
    "leantime-bridge": {
      "type": "sse",
      "url": "http://localhost:3015/sse",
      "env": {
        "LEANTIME_API_TOKEN": "REPLACE_WITH_LEANTIME_API_TOKEN"
      },
      "description": "Leantime project management integration bridge"
    },
    "exa": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-exa",
        "python",
        "/app/exa_server.py"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "description": "Neural web search via Docker container"
    },
    "dope-context": {
      "type": "sse",
      "url": "http://localhost:3010/mcp",
      "env": {
        "VOYAGE_API_KEY": "${VOYAGEAI_API_KEY}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@context7/mcp-server"
      ]
    },
    "desktop-commander": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-desktop-commander",
        "python",
        "/app/mcp_server.py"
      ],
      "env": {
        "DISPLAY": "${DISPLAY:-:0}"
      },
      "description": "Desktop automation via Docker container"
    },
    "task-orchestrator": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/Users/hue/code/dopemux-mvp/services/task-orchestrator/server.py"
      ],
      "env": {
        "WORKSPACE_ID": "/Users/hue/code/dopemux-mvp"
      },
      "description": "Advanced task orchestration and dependency management with 37 tools"
    },
  }
}
