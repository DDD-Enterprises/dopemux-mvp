{
  "mcpServers": {
    "zen": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-zen",
        "bash",
        "-c",
        "source /app/.venv/bin/activate && python3 server.py"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY:-}",
        "GEMINI_API_KEY": "${GEMINI_API_KEY:-AIzaSyCkYsYc73ouBiRw8nryattIKzEI_qP5UEw}",
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY:-AIzaSyCkYsYc73ouBiRw8nryattIKzEI_qP5UEw}",
        "XAI_API_KEY": "${XAI_API_KEY:-xai-ZkmIhVJxh5MbOVzKwRecajBn5O7Jdr1NWuK8u7xtVi93hi6ESaprl7D4itYrgCoebO7mUBknKToAtcEt}",
        "DISABLED_TOOLS": "refactor,testgen,secaudit,docgen,tracer",
        "DEFAULT_MODEL": "auto"
      }
    },
    "desktop-commander": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/Users/hue/code/dopemux-mvp/docker/mcp-servers/desktop-commander/stdio_bridge.py"
      ],
      "env": {}
    }
  }
}
