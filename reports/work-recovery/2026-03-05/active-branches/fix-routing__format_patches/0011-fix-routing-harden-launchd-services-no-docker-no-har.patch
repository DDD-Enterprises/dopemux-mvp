+    def sync_keys_from_environment(self) -> None:
+        """Sync API keys from current environment to routing.env."""
+        env_path = self.DOPEMUX_DIR / "routing.env"
+        
+        # Load existing env file
+        existing_vars = {}
+        if env_path.exists():
+            with open(env_path, "r") as f:
+                for line in f:
+                    line = line.strip()
+                    if line and not line.startswith("#") and "=" in line:
+                        key, value = line.split("=", 1)
+                        existing_vars[key] = value
+        
+        # Provider API keys to sync from environment
+        provider_keys = [
+            "XAI_API_KEY",
+            "OPENROUTER_API_KEY",
+            "OPENAI_API_KEY",
+            "GEMINI_API_KEY",
+            "DEEPSEEK_API_KEY",
+        ]
+        
+        # Update with values from current environment if present
+        for key in provider_keys:
+            if key in os.environ and os.environ[key]:
+                existing_vars[key] = os.environ[key]
+        
+        # Write updated file
+        with open(env_path, "w") as f:
+            f.write("# Dopemux Routing Environment Variables\n")
+            f.write("# Generated by dopemux launchd services\n")
+            f.write("# Keys synced from current environment\n\n")
+            
+            for key, value in existing_vars.items():
+                f.write(f"{key}={value}\n")
+        
+        logger.info(f"Synced API keys to routing environment file: {env_path}")
+
