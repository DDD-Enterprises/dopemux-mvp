Subject: [PATCH 26/36] chore(ci): update workflow for dopetask

---
 .dockerignore                     |  4 ++++
 .github/workflows/ci-complete.yml | 33 ++++++++++++-------------------
 .gitignore                        | 16 +++++++++++++--
 3 files changed, 31 insertions(+), 22 deletions(-)

diff --git a/.dockerignore b/.dockerignore
index 2ec39fe50..d536a7e8e 100644
--- a/.dockerignore
+++ b/.dockerignore
@@ -48,6 +48,7 @@ build/
 *.egg
 .eggs/
 .venv-taskx
+.dopetask_venv
 .venv-*
 
 # Node specific
@@ -82,6 +83,9 @@ temp/
 .taskx
 .taskx-pin
 .taskxroot
+.dopetask
+.dopetask-pin
+.dopetaskroot
 
 # Project specific
 SYSTEM_ARCHIVE/
diff --git a/.github/workflows/ci-complete.yml b/.github/workflows/ci-complete.yml
index 1f26052a4..74d6376d3 100644
--- a/.github/workflows/ci-complete.yml
+++ b/.github/workflows/ci-complete.yml
@@ -165,32 +165,25 @@ jobs:
           pip install -r requirements.txt
           pip install -e .[dev]
 
-      - name: 📦 Setup TaskX venv from submodule
+      - name: 📦 Setup dopeTask venv from pip
         run: |
-          if [ ! -d .taskx_venv ]; then
-            python -m venv .taskx_venv
+          if [ ! -d .dopetask_venv ]; then
+            python -m venv .dopetask_venv
           fi
-          .taskx_venv/bin/pip install --upgrade pip
-          .taskx_venv/bin/pip install --upgrade -e ./vendor/taskx
+          .dopetask_venv/bin/pip install --upgrade pip
+          .dopetask_venv/bin/pip install --upgrade dopetask==0.1.4
 
-      - name: ✅ Verify TaskX wiring
+      - name: ✅ Verify dopeTask wiring
         run: |
-          test -f .gitmodules
-          test -d vendor/taskx
-          test -f vendor/taskx/pyproject.toml
-          SUBMODULE_STATUS="$(git submodule status -- vendor/taskx)"
-          echo "$SUBMODULE_STATUS"
-          if [[ "$SUBMODULE_STATUS" == -* || "$SUBMODULE_STATUS" == +* ]]; then
-            echo "TaskX submodule is not in the pinned clean state."
-            exit 1
-          fi
-          test -f .taskxroot
-          test -d .taskx_venv
-          test -x scripts/taskx
+          test -f .dopetask-pin
+          test -f .dopetaskroot
+          test -d .dopetask_venv
+          test -x scripts/dopetask
+          .dopetask_venv/bin/dopetask --version | grep -q "0.1.4"
 
-      - name: 🧠 TaskX doctor
+      - name: 🧠 dopeTask doctor
         run: |
-          scripts/taskx doctor --timestamp-mode deterministic
+          scripts/dopetask doctor --timestamp-mode deterministic
 
       - name: ▶️ Run Pytest (unit suite)
         run: |
