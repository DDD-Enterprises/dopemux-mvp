+# Dopemux Global Routing Configuration
+#
+# This file defines the global LiteLLM routing strategy for all Dopemux instances
+# on this macOS user account. It is managed by `dopemux routing` commands.
+#
+# DO NOT EDIT THIS FILE DIRECTLY unless you understand the full implications.
+# Use `dopemux routing edit` to safely modify and validate changes.
+#
+# Changes require `dopemux routing reload` to take effect.
+
+version: 1
+
+# Routing mode: determines how Claude Code requests are handled
+# - "subscription": Direct to Anthropic (no proxy, requires ANTHROPIC_API_KEY)
+# - "api": Route through global LiteLLM proxy (requires LiteLLM services)
+mode: subscription
+
+# Port configuration for LiteLLM and CCR services
+ports:
+  litellm: 4000
+  ccr: 4010
+
+# Provider definitions - API keys are NOT stored here
+# Keys must be in ~/.dopemux/routing.env
+providers:
+  - name: xai
+    label: "xAI Grok"
+    api_key_env: "XAI_API_KEY"
+    base_url: "https://api.x.ai/v1"
+    
+  - name: openrouter
+    label: "OpenRouter"
+    api_key_env: "OPENROUTER_API_KEY"
+    base_url: "https://openrouter.ai/api/v1"
+    extra_headers:
+      HTTP-Referer: "https://dopemux.local"
+      X-Title: "Dopemux LiteLLM Proxy"
+
+# Model definitions - reference providers by name
+models:
+  - name: grok-4-fast
+    provider: xai
+    model_id: "xai/grok-4-fast"
+    max_tokens: 131072
+    
+  - name: xai-grok-code-fast
+    provider: xai
+    model_id: "xai/grok-code-fast"
+    max_tokens: 131072
+    
+  - name: openrouter-gpt-5
+    provider: openrouter
+    model_id: "openrouter/openai/gpt-5"
+    max_tokens: 32768
+    
+  - name: openrouter-gpt-5-codex
+    provider: openrouter
+    model_id: "openrouter/openai/gpt-5-codex"
+    max_tokens: 32768
+
+# Slot definitions - assign models to usage slots
+# These are exposed to Claude Code via CCR
+slots:
+  default: grok-4-fast
+  codex: xai-grok-code-fast
+  opus: openrouter-gpt-5-codex
+  sonnet: xai-grok-code-fast
+  haiku: grok-4-fast
+
+# Fallback chain for resilience
+fallbacks:
+  grok-4-fast:
+    - xai-grok-code-fast
+    - openrouter-gpt-5
+  xai-grok-code-fast:
+    - grok-4-fast
+    - openrouter-gpt-5-codex
+  openrouter-gpt-5:
+    - grok-4-fast
+    - openrouter-gpt-5-codex
+  openrouter-gpt-5-codex:
+    - openrouter-gpt-5
+    - grok-4-fast
+
+# Default fallback list (ordered)
+default_fallbacks:
+  - xai-grok-code-fast
+  - grok-4-fast
+
+# Model alias map for compatibility
+# Maps common model names to Dopemux slot names
+aliases:
+  grok-4: default
+  grok: default
+  grok-code: codex
+  claude-sonnet: sonnet
+  claude-sonnet-4-5-20250929: sonnet
+  claude-sonnet-4.5: sonnet
+  claude-sonnet-4: sonnet
+  claude-haiku: haiku
+  claude-opus: opus
+  claude-opus-4-1-20250805: opus
+  claude-opus-4-20250514: opus
+  claude-opus-4: opus
+  claude-4: sonnet
+  claude-4-sonnet: sonnet
+  claude-4-opus: opus
+  claude-3.7: sonnet
+  claude-3-7-sonnet-20250219: sonnet
+  claude-3.5: sonnet
+  claude-3-5-sonnet-20240620: sonnet
+  claude-3-5-sonnet-20241022: sonnet
+  anthropic/claude-3-5-sonnet-latest: sonnet
+  xai/grok-code-fast: codex
+  gpt-5: sonnet
+  codex: codex
