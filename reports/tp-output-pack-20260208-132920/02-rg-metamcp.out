s": {"phase_1_postgres": {"goal": "3 PostgreSQL \u2192 1 (dopemux-postgres-age only)", "safe_removals": ["dopemux-postgres (orphaned)", "conport-kg-postgres-age (DEFERRED)"], "requires_investigation": "dopemux-postgres-primary (mystery source)", "estimated_savings": "~1GB memory, 2 containers"}, "phase_2_redis": {"goal": "Redis consolidation to 2-3 instances", "keep": "dopemux-redis-leantime (PM plane isolation)", "requires_investigation": "dopemux-redis-primary (mystery source)", "target_architecture": "shared Redis + events Redis + Leantime Redis"}, "phase_3_vector": {"goal": "Milvus (3 containers) \u2192 Qdrant (1 container)", "migration_effort": "MEDIUM-HIGH", "risk": "Data migration, re-indexing time", "estimated_savings": "~1.5GB memory, 3 containers"}}, "zen_analysis_steps": {"step_1": "Evidence gathering: Find mystery container sources, inspect databases, check MCP configs", "step_2": "Dependency mapping: Which services depend on which databases (postgres-primary, redis-primary)", "step_3": "Data safety assessment: What data exists, is it needed, can we migrate/remove safely", "step_4": "Risk analysis: What breaks if we remove each container, rollback strategies", "step_5": "Execution planning: Optimal sequence, validation checkpoints, rollback procedures", "step_6": "Validation strategy: How to verify each phase succeeded, monitoring during execution", "step_7": "Final synthesis: Go/no-go decision, detailed execution runbook"}, "mcp_servers_to_check": ["ConPort MCP - which database? (likely postgres-age)", "dope-context - which vector DB? (likely Qdrant)", "claude-context - which vector DB? (likely Milvus)", "Serena - any database dependencies?", "GPT-Researcher - any database dependencies?"], "investigation_commands": {"find_compose_files": "find . -name 'docker-compose*.yml' -type f | grep -v node_modules", "inspect_postgres_primary": "docker exec dopemux-postgres-primary psql -U postgres -c '\\l'", "inspect_redis_primary": "docker exec dopemux-redis-prim