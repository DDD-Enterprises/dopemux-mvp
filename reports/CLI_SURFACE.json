{
    "entrypoints": [
        {
            "name": "dopemux",
            "command": "dopemux",
            "module": "dopemux.cli",
            "function": "main",
            "file": "src/dopemux/cli.py",
            "description": "ADHD-optimized development platform CLI"
        },
        {
            "name": "genetic-agent",
            "command": "genetic-agent",
            "module": "genetic_agent.cli",
            "function": "cli",
            "file": "services/genetic_agent/genetic_agent/cli.py",
            "description": "Intelligent Code Repair CLI"
        }
    ],
    "command_groups": {
        "instances": {
            "description": "Manage parallel worktrees and session recovery",
            "commands": [
                {
                    "name": "list",
                    "description": "List all running and orphaned instances"
                },
                {
                    "name": "resume",
                    "description": "Resume an orphaned/crashed instance with context"
                },
                {
                    "name": "cleanup",
                    "description": "Remove stopped instance worktrees"
                }
            ]
        },
        "extract": {
            "description": "ADHD-optimized document extraction pipeline",
            "commands": [
                {
                    "name": "docs",
                    "description": "Extract entities from markdown/YAML docs"
                },
                {
                    "name": "pipeline",
                    "description": "Run unified multi-layer extraction pipeline"
                },
                {
                    "name": "cleanup",
                    "description": "Clean pipeline artifacts and generate report"
                }
            ]
        },
        "memory": {
            "description": "Chronicle capture and global rollup index",
            "groups": {
                "rollup": {
                    "commands": [
                        {
                            "name": "build",
                            "description": "Build global index from project ledgers"
                        },
                        {
                            "name": "list",
                            "description": "List registered projects"
                        },
                        {
                            "name": "search",
                            "description": "Search promoted work log entries"
                        }
                    ]
                },
                "capture": {
                    "commands": [
                        {
                            "name": "emit",
                            "description": "Manually emit event to Chronicle"
                        },
                        {
                            "name": "copilot",
                            "description": "Ingest Copilot CLI session transcript"
                        },
                        {
                            "name": "copilot-list",
                            "description": "List available Copilot sessions"
                        }
                    ]
                }
            }
        },
        "workflow": {
            "description": "Idea and Epic management system",
            "groups": {
                "ideas": [
                    {
                        "name": "add",
                        "description": "Capture new workflow ideas"
                    },
                    {
                        "name": "promote",
                        "description": "Promote idea to Epic/Leantime"
                    }
                ],
                "epics": [
                    {
                        "name": "list",
                        "description": "List active workflow epics"
                    }
                ]
            }
        },
        "shortcuts": {
            "description": "Quick launch presets for tmux environments",
            "commands": [
                {
                    "name": "launch",
                    "description": "Opinionated presets (minimal, standard, full)"
                },
                {
                    "name": "dope",
                    "description": "Full DOPE layout with all monitors"
                },
                {
                    "name": "quick",
                    "description": "Fast start with medium layout"
                }
            ]
        }
    },
    "core_commands": [
        {
            "name": "start",
            "description": "Start ADHD-optimized Claude Code session"
        },
        {
            "name": "status",
            "description": "Show attention, context, and task metrics"
        },
        {
            "name": "init",
            "description": "Initialize Dopemux in project"
        },
        {
            "name": "doctor",
            "description": "System health and dependency check"
        },
        {
            "name": "analyze",
            "description": "Deep codebase semantic analysis"
        },
        {
            "name": "run-tests",
            "description": "Run tests with mobile notifications"
        },
        {
            "name": "run-build",
            "description": "Run build with mobile notifications"
        }
    ],
    "internal_scripts": [
        {
            "name": "session-manager",
            "module": "session_manager.main",
            "file": "services/session-manager/src/session_manager/main.py",
            "description": "Orchestration system for Dopemux sessions"
        },
        {
            "name": "adhd-engine-metrics",
            "file": "services/adhd_engine/adhd_metrics_server.py",
            "description": "ADHD Engine Prometheus metrics exporter"
        }
    ]
}