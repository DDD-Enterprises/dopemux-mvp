# Dopemux Configuration Template
# Copy this file to .env and fill in your actual values

# Database
AGE_PASSWORD=your_secure_age_password_here

# Redis
REDIS_PASSWORD=your_secure_redis_password_here

# Vector Database
QDRANT_API_KEY=your_qdrant_api_key_here

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENROUTER_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
VOYAGE_API_KEY=
TAVILY_API_KEY=

# Alternative Provider (ALTP) Tier-Specific Keys
# These keys are used when --altp flag is enabled for model routing
# Each tier can use a different provider/API key
ALTP_OPUS_KEY=  # For altp-opus tier (high thinking tasks)
ALTP_SONNET_KEY=  # For altp-sonnet tier (balanced tasks)
ALTP_HAIKU_KEY=  # For altp-haiku tier (fast tasks)

# Frontend
FRONTEND_API_URL=http://localhost:8000

# Optional Service URLs
LEANTIME_URL=http://leantime:80
LEANTIME_TOKEN=

# Environment
ENVIRONMENT=development
LOG_LEVEL=info
