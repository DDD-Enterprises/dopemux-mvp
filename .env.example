# Dopemux Configuration Template
# Copy this file to .env and fill in your actual values

# Database
AGE_PASSWORD=your_secure_age_password_here

# Redis
REDIS_PASSWORD=your_secure_redis_password_here

# Vector Database
QDRANT_API_KEY=your_qdrant_api_key_here

# API Keys
ADHD_ENGINE_API_KEY=your_secure_adhd_engine_key_here
TASK_ORCHESTRATOR_API_KEY=your_secure_task_orchestrator_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENROUTER_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
VOYAGE_API_KEY=
TAVILY_API_KEY=

# Frontend
FRONTEND_API_URL=http://localhost:8000

# Optional Service URLs
LEANTIME_URL=http://leantime:80
LEANTIME_TOKEN=

# Environment
ENVIRONMENT=development
LOG_LEVEL=info
