# Dopemux MVP Environment Configuration
# Copy this file to .env and fill in your actual values
# .env is gitignored and should NEVER be committed

# ================================
# DATABASE
# ================================
AGE_PASSWORD=dopemux_age_dev_password
LITELLM_DATABASE_URL=postgresql://dopemux_age:dopemux_age_dev_password@dopemux-postgres-age:5432/litellm

# ================================
# API KEYS (Get from service providers)
# ================================
OPENAI_API_KEY=sk-...your-key-here
ANTHROPIC_API_KEY=sk-ant-...your-key-here
OPENROUTER_API_KEY=sk-or-...your-key-here
GEMINI_API_KEY=...your-key-here
XAI_API_KEY=...your-key-here
TAVILY_API_KEY=...your-key-here
EXA_API_KEY=...your-key-here
PERPLEXITY_API_KEY=...your-key-here
VOYAGEAI_API_KEY=...your-key-here

# ================================
# SERVICE URLS
# ================================
LEANTIME_URL=http://leantime:80
LEANTIME_API_TOKEN=...your-token-here
LEANTIME_TOKEN=...your-token-here

# ================================
# API KEYS (Internal)
# ================================
ADHD_ENGINE_API_KEY=dev-key-123
TASK_ORCHESTRATOR_API_KEY=dev-key-456

# ================================
# WORKSPACE CONFIGURATION
# ================================
WORKSPACE_ID=/Users/hue/code/dopemux-mvp
DEFAULT_WORKSPACE_PATH=/Users/hue/code/dopemux-mvp
DISPLAY=:0

# ================================
# DOCKER COMPOSE SETTINGS
# ================================
# Name for the docker compose project (used for container naming)
COMPOSE_PROJECT_NAME=dopemux

# ================================
# DOPE-MEMORY MIRROR
# ================================
MIRROR_RAW_TTL_CAP_DAYS=7
