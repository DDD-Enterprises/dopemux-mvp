# Copy to .env and fill in your real values.

# Core AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=

# Research/search providers
EXA_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
VOYAGEAI_API_KEY=

# MCP + integrations
LEAN_MCP_TOKEN=
DOPEMUX_INSTANCE_ID=
DOPEMUX_WORKSPACE_ID=

# DopeconBridge - Central coordination layer
DOPECON_BRIDGE_URL=http://localhost:3016
DOPECON_BRIDGE_TOKEN=
DOPECON_BRIDGE_SOURCE_PLANE=cognitive_plane

# Optional: LiteLLM DB (override if using external DB)
# LITELLM_DATABASE_URL=postgresql://dopemux_age:dopemux_age_dev_password@dopemux-postgres-age:5432/litellm

# Optional: Leantime credentials (if you run docker/leantime)
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=leantime
MYSQL_USER=leantime
MYSQL_PASSWORD=
LEAN_SITENAME=Dopemux Leantime
LEAN_SESSION_PASSWORD=
LEAN_APP_URL=http://localhost:8080
REDIS_PASSWORD=

# Optional: host paths
# DOPEMUX_CODE_PARENT=~/code

