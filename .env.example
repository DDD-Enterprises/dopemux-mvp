# Copy to .env and fill in your real values.

# Core AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=

# Research/search providers
EXA_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
VOYAGE_API_KEY=
VOYAGEAI_API_KEY=

# MCP + integrations
LEANTIME_TOKEN=
LEANTIME_URL=http://localhost:8080
LEAN_MCP_TOKEN=
TASK_ORCHESTRATOR_API_KEY=
ADHD_ENGINE_API_KEY=
AGE_PASSWORD=
DOPEMUX_INSTANCE_ID=
DOPEMUX_WORKSPACE_ID=
WORKSPACE_ID=

# Multi-Workspace Support
# Default workspace path (used when no explicit workspace specified)
DEFAULT_WORKSPACE_PATH=~/code/dopemux-mvp

# Additional workspace paths (comma-separated for multi-workspace queries)
# Example: WORKSPACE_PATHS=~/code/project1,~/code/project2,~/code/project3
WORKSPACE_PATHS=

# Workspace-specific features
ENABLE_WORKSPACE_ISOLATION=true  # Isolate data per workspace
ENABLE_CROSS_WORKSPACE_QUERIES=true  # Allow queries across workspaces
WORKSPACE_CACHE_TTL=3600  # Workspace cache TTL in seconds

# DopeconBridge - Central coordination layer
DOPECON_BRIDGE_URL=http://localhost:3016
DOPECON_BRIDGE_TOKEN=
DOPECON_BRIDGE_SOURCE_PLANE=cognitive_plane

# Optional: LiteLLM DB (override if using external DB)
# LITELLM_DATABASE_URL=postgresql://dopemux_age:dopemux_age_dev_password@dopemux-postgres-age:5432/litellm

# Optional: Leantime credentials (if you run docker/leantime)
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=leantime
MYSQL_USER=leantime
MYSQL_PASSWORD=
LEAN_SITENAME=Dopemux Leantime
LEAN_SESSION_PASSWORD=
LEAN_APP_URL=http://localhost:8080
REDIS_PASSWORD=

# Optional: host paths
# DOPEMUX_CODE_PARENT=~/code


# ══════════════════════════════════════════════════════════════════════════════
# Dope-Memory Configuration (Phase 2)
# ══════════════════════════════════════════════════════════════════════════════

# Session idle detection threshold (minutes)
# After this period of inactivity, session is considered idle
DOPE_MEMORY_IDLE_MINUTES=20

# Pulse emission interval (seconds) - base interval for memory.pulse events
# Default: 2700s (45 minutes)
DOPE_MEMORY_PULSE_INTERVAL_SECONDS=2700

# Pulse jitter range (seconds) - randomization to avoid synchronization storms
# Actual interval: PULSE_INTERVAL ± PULSE_JITTER
DOPE_MEMORY_PULSE_JITTER_SECONDS=300

# Reflection minimum window (minutes) - minimum time between reflections
# Prevents duplicate reflections from being generated too quickly
DOPE_MEMORY_REFLECTION_MIN_WINDOW_MINUTES=30

# Reflection maximum window (hours) - periodic reflection boundary
# Triggers reflection even if session is still active after this duration
DOPE_MEMORY_REFLECTION_MAX_WINDOW_HOURS=2

# Reflection cooldown (seconds) - additional safeguard against duplicates
# Currently not enforced separately from MIN_WINDOW
DOPE_MEMORY_REFLECTION_COOLDOWN_SECONDS=300

# DopeContext indexing feature flag
# Enable semantic indexing of curated work logs in DopeContext vector store
ENABLE_DOPECONTEXT_INDEX=false

# DopeContext service URL (if indexing enabled)
DOPECONTEXT_URL=http://localhost:3010
