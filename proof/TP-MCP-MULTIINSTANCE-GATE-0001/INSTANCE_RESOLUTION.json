{
  "instance_profile": "default",
  "project_id": "dopemux-mvp",
  "provenance": {
    "conport": "repo_profile",
    "docker_mcp_gateway": "global_fallback",
    "dope_context": "repo_profile",
    "dope_memory": "repo_profile",
    "serena": "repo_profile"
  },
  "servers": {
    "conport": {
      "required_tool_globs": [
        "conport_*"
      ],
      "transport": "http",
      "url": "http://127.0.0.1:3005"
    },
    "docker_mcp_gateway": {
      "transport": "streamable-http",
      "url": "http://localhost:3020"
    },
    "dope_context": {
      "required_tool_globs": [
        "dope_context_*"
      ],
      "transport": "http",
      "url": "http://127.0.0.1:3010"
    },
    "dope_memory": {
      "required_tool_globs": [
        "dope_memory_*"
      ],
      "transport": "http",
      "url": "http://127.0.0.1:3020"
    },
    "serena": {
      "required_tool_globs": [
        "serena_*"
      ],
      "transport": "streamable-http",
      "url": "http://127.0.0.1:3006"
    }
  }
}