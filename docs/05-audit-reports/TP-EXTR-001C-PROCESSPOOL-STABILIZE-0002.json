  "objective": {
    "title": "Stabilize ProcessPoolExecutor for Phase A Processing",
    "description": "Make workers=4 run complete Phase A collection without early abort, and convert missing/invalid results into per-partition failures, not phase-kill.",
    "acceptance_criteria": [
      "submitted == completed == 252 (or expected count)",
      "workers=4 yields expected raw_total with raw_ok + raw_failed = partition_count",
      "if any failures exist, they are enumerated by partition id",
      "determinism compare can run (because output sets are complete)"
    ],
    "success_conditions": [
      "Phase A completes with workers=4 without KeyError abort",
      "All 252 partitions processed and accounted for",
      "Individual partition failures logged with IDs",
      "No silent drops - raw_ok + raw_failed = partition_count"
    ]
  },
  "error_encountered": {
    "id": "ERROR-20240226-0450",
    "type": "KeyError",
    "message": "'kind'",
    "stack_trace": "Phase A failed: 'kind' at op['kind'] in _apply_write_ops",
    "first_observed": "2024-02-25T23:45:00Z",
    "last_observed": "2024-02-26T04:45:00Z",
    "frequency": "100% with workers=4",
    "impact": "Phase A aborts early at partition 21, only 21/252 partitions processed",
    "root_cause": "Direct dictionary access op['kind'] without defensive programming",
    "trigger": "Concurrent execution with workers=4 exposes timing-dependent missing 'kind' field"
  },
  "changes_implemented": [
    {
      "file": "services/repo-truth-extractor/run_extraction_v3.py",
      "function": "_apply_write_ops",
      "line": 6183,
      "change_type": "DEFENSIVE_PROGRAMMING",
      "before": "kind = op['kind']  # KeyError if missing",
      "after": "kind = op.get('kind')\nif kind is None:\n    logger.error(...)\n    continue",
      "impact": "Eliminates KeyError, logs and continues processing"
    },
    {
      "file": "services/repo-truth-extractor/run_extraction_v3.py",
      "function": "execute_step_for_partitions",
      "line": 7185,
      "change_type": "ENHANCED_LOGGING",
      "before": "results_by_partition[partition_id] = future.result()",
      "after": "logger.info('Processing completed future for partition %s', partition_id)\nresult = future.result()\nlogger.debug('Successfully got result for partition %s', partition_id)",
      "impact": "Tracks which partition is being processed, provides success confirmation"
    },
    {
      "file": "services/repo-truth-extractor/run_extraction_v3.py",
      "function": "execute_step_for_partitions",
      "line": 7259,
      "change_type": "PRE_VALIDATION",
      "before": "_apply_write_ops(result.write_ops)",
      "after": "# Validate write_ops before applying them\nfor i, op in enumerate(result.write_ops):\n    if 'kind' not in op:\n        logger.error(...)\n        result.write_ops[i]['kind'] = 'unknown'\n    if 'path' not in op:\n        logger.error(...)\n        result.write_ops[i]['path'] = '/dev/null'\n_apply_write_ops(result.write_ops)",
      "impact": "Catches malformed operations before they cause crashes, provides defensive defaults"
    }
  ],
