# litellm.config.yaml

model_list:
  - model_name: openrouter-xai-grok-code-fast
    litellm_params:
      model: openrouter/xai/grok-code-fast-1
      api_key: os.environ/OPENROUTER_API_KEY
      api_base: https://openrouter.ai/api/v1
      max_output_tokens: 65536
      rpm: 100
      tpm: 4000000
      extra_headers:
        HTTP-Referer: https://dopemux.local
        Referer: https://dopemux.local
        X-Title: Dopemux LiteLLM Proxy
        User-Agent: Dopemux LiteLLM Proxy
  - model_name: openrouter-openai-gpt-5
    litellm_params:
      model: openrouter/openai/gpt-5
      api_key: os.environ/OPENROUTER_API_KEY
      api_base: https://openrouter.ai/api/v1
      max_output_tokens: 32768
      rpm: 500
      tpm: 2000000
      extra_headers:
        HTTP-Referer: https://dopemux.local
        Referer: https://dopemux.local
        X-Title: Dopemux LiteLLM Proxy
        User-Agent: Dopemux LiteLLM Proxy
  - model_name: openrouter-openai-gpt-5-codex
    litellm_params:
      model: openrouter/openai/gpt-5-codex
      api_key: os.environ/OPENROUTER_API_KEY
      api_base: https://openrouter.ai/api/v1
      max_output_tokens: 32768
      extra_headers:
        HTTP-Referer: https://dopemux.local
        Referer: https://dopemux.local
        X-Title: Dopemux LiteLLM Proxy
        User-Agent: Dopemux LiteLLM Proxy
  - model_name: openrouter-openai-gpt-5-mini
    litellm_params:
      model: openrouter/openai/gpt-5-mini
      api_key: os.environ/OPENROUTER_API_KEY
      api_base: https://openrouter.ai/api/v1
      max_output_tokens: 16384
      extra_headers:
        HTTP-Referer: https://dopemux.local
        Referer: https://dopemux.local
        X-Title: Dopemux LiteLLM Proxy
        User-Agent: Dopemux LiteLLM Proxy
  - model_name: openrouter-google-gemini-2-flash
    litellm_params:
      model: openrouter/google/gemini-2.0-flash-exp
      api_key: os.environ/OPENROUTER_API_KEY
      api_base: https://openrouter.ai/api/v1
      max_output_tokens: 30720
      extra_headers:
        HTTP-Referer: https://dopemux.local
        Referer: https://dopemux.local
        X-Title: Dopemux LiteLLM Proxy
        User-Agent: Dopemux LiteLLM Proxy
  - model_name: openrouter-meta-llama-3.1-405b
    litellm_params:
      model: openrouter/meta-llama/llama-3.1-405b-instruct
      api_key: os.environ/OPENROUTER_API_KEY
      api_base: https://openrouter.ai/api/v1
      max_output_tokens: 32768
      extra_headers:
        HTTP-Referer: https://dopemux.local
        Referer: https://dopemux.local
        X-Title: Dopemux LiteLLM Proxy
        User-Agent: Dopemux LiteLLM Proxy

router:
  fallback:
    - openrouter-openai-gpt-5
    - openrouter-xai-grok-code-fast
    - openrouter-openai-gpt-5-codex
    - openrouter-openai-gpt-5-mini
    - openrouter-google-gemini-2-flash
    - openrouter-meta-llama-3.1-405b

proxy:
  host: 0.0.0.0
  port: 4000

# Logging, rate limiting, optional:
litellm_params:
  request_timeout: 90
  log_level: INFO

rate_limits:
  openrouter-xai-grok-code-fast: 120
  openrouter-openai-gpt-5: 80
  openrouter-openai-gpt-5-codex: 60
  openrouter-openai-gpt-5-mini: 150
  openrouter-google-gemini-2-flash: 100
  openrouter-meta-llama-3.1-405b: 40
