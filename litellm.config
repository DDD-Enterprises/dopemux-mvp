# litellm.config.yaml

model_list:
  # Primary Claude models
  - model_name: anthropic/claude-3-sonnet-20240229-v1:beta
    litellm_params: { max_output_tokens: 4096 }
    provider: anthropic
  - model_name: anthropic/claude-3-sonnet-20240229-1m:beta
    litellm_params: { max_output_tokens: 1000000 }
    provider: anthropic
  # Opus backup
  - model_name: anthropic/claude-3-opus-20240229-v1:beta
    litellm_params: { max_output_tokens: 4096 }
    provider: anthropic

  # OpenAI GPT-5
  - model_name: openai/gpt-5
    provider: openai
  - model_name: openai/gpt-5-mini
    provider: openai

  # xAI Grok
  - model_name: xai/grok-code-4
    provider: xai
  - model_name: xai/grok-code-fast
    provider: xai

router:
  fallback:
    - anthropic/claude-3-sonnet-20240229-v1:beta
    - anthropic/claude-3-sonnet-20240229-1m:beta
    - anthropic/claude-3-opus-20240229-v1:beta
    - openai/gpt-5
    - openai/gpt-5-mini
    - xai/grok-code-4
    - xai/grok-code-fast

proxy:
  host: 0.0.0.0
  port: 4000

# Logging, rate limiting, optional:
litellm_params:
  request_timeout: 90
  log_level: INFO

# Optionally configure per-model rate limits
rate_limits:
  anthropic/claude-3-sonnet-20240229-v1:beta: 50 # requests per minute
  anthropic/claude-3-sonnet-20240229-1m:beta: 15
  anthropic/claude-3-opus-20240229-v1:beta: 10
  openai/gpt-5: 80
  openai/gpt-5-mini: 150
  xai/grok-code-4: 15
  xai/grok-code-fast: 25

