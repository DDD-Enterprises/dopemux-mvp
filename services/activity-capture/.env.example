# Redis Configuration
REDIS_URL=redis://dopemux-redis-events:6379

# Event Stream Configuration
STREAM_NAME=dopemux:events
CONSUMER_GROUP=activity-capture
CONSUMER_NAME=activity-capture-1

# ADHD Engine Configuration
ADHD_ENGINE_URL=http://adhd-engine:8095
ADHD_USER_ID=hue

# Activity Tracking Configuration
AGGREGATION_WINDOW_SECONDS=300  # 5 minutes
DEFAULT_COMPLEXITY=0.5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8096
LOG_LEVEL=INFO
