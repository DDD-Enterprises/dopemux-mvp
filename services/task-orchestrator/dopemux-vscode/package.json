{
  "name": "dopemux-vscode",
  "displayName": "Dopemux",
  "description": "ADHD-optimized development workflow hooks for Dopemux",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dopemux.enableHooks",
        "title": "Enable Dopemux Hooks"
      },
      {
        "command": "dopemux.disableHooks",
        "title": "Disable Dopemux Hooks"
      },
      {
        "command": "dopemux.showStatus",
        "title": "Show Dopemux Hook Status"
      }
    ],
    "configuration": {
      "title": "Dopemux",
      "properties": {
        "dopemux.hooks.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Dopemux workflow hooks"
        },
        "dopemux.hooks.save.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable file save hooks"
        },
        "dopemux.hooks.terminal.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable terminal open hooks"
        },
        "dopemux.hooks.quiet": {
          "type": "boolean",
          "default": true,
          "description": "Run hooks silently without notifications"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "eslint": "^8.31.0",
    "typescript": "^4.9.4",
    "@typescript-eslint/eslint-plugin": "^5.48.2",
    "@typescript-eslint/parser": "^5.48.2"
  }
}