{
  "description": "Single runtime/service application layout.",
  "match_weights": {
    "is_single_service": 3.0,
    "is_monorepo": -1.0,
    "services_root_count_norm": -1.0
  },
  "phase_policy": {
    "budgets_by_phase": {
      "C": {"file_truncate_chars": 80000, "max_chars": 780000, "max_files": 28},
      "E": {"file_truncate_chars": 80000, "max_chars": 780000, "max_files": 24}
    },
    "prompt_variants_by_phase_step": {
      "C": {"C0": "deep_single_service"}
    },
    "targets_by_phase": {
      "C": ["src", "services", "shared", "scripts", "tests"],
      "E": ["scripts", "src", "services", "compose", ".github"]
    }
  },
  "priority": 80,
  "profile_id": "P02_SINGLE_SERVICE_APP",
  "prompt_overlays": {
    "base": "Favor deep coverage over breadth."
  },
  "selection_threshold": 1.5,
  "v2_rules": {
    "RULE_ENABLE_STRICT_ENVELOPE_ON_PARSE": {"enabled": true},
    "RULE_REDUCE_MAX_FILES_ON_PARSE_OR_EMPTY": {"decrement": 2, "enabled": true, "threshold": 2},
    "RULE_SHRINK_BUDGET_ON_PAYLOAD_UNSHRINKABLE": {"enabled": true, "factor": 0.85, "threshold": 1},
    "RULE_SPLIT_STEP_ON_MISSING_ARTIFACTS": {"enabled": true, "threshold": 0.4},
    "RULE_TARGET_REORDER_ON_THIN_COVERAGE": {"enabled": true, "threshold": 0.65}
  },
  "version": "1.0.0"
}
