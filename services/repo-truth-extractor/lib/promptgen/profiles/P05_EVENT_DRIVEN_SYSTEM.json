{
  "description": "Event-driven system with producers/consumers and taxonomy contracts.",
  "match_weights": {
    "is_event_driven": 3.0,
    "has_event_contracts": 2.5,
    "is_microservices": 1.0
  },
  "phase_policy": {
    "budgets_by_phase": {
      "C": {"file_truncate_chars": 65000, "max_chars": 560000, "max_files": 14},
      "E": {"file_truncate_chars": 65000, "max_chars": 560000, "max_files": 14},
      "Q": {"file_truncate_chars": 65000, "max_chars": 560000, "max_files": 14}
    },
    "prompt_variants_by_phase_step": {
      "C": {"C2": "contracts_first", "C3": "contracts_first"},
      "E": {"E3": "contracts_first"},
      "Q": {"Q1": "contracts_first"}
    },
    "targets_by_phase": {
      "C": ["services", "src", "shared", "schemas", "contracts", "docs"],
      "E": ["services", "scripts", "compose", "src"]
    }
  },
  "priority": 85,
  "profile_id": "P05_EVENT_DRIVEN_SYSTEM",
  "prompt_overlays": {
    "base": "Treat declared event taxonomies and schemas as authoritative contracts."
  },
  "selection_threshold": 2.2,
  "v2_rules": {
    "RULE_ENABLE_STRICT_ENVELOPE_ON_PARSE": {"enabled": true},
    "RULE_REDUCE_MAX_FILES_ON_PARSE_OR_EMPTY": {"decrement": 3, "enabled": true, "threshold": 1},
    "RULE_SHRINK_BUDGET_ON_PAYLOAD_UNSHRINKABLE": {"enabled": true, "factor": 0.72, "threshold": 1},
    "RULE_SPLIT_STEP_ON_MISSING_ARTIFACTS": {"enabled": true, "threshold": 0.25},
    "RULE_TARGET_REORDER_ON_THIN_COVERAGE": {"enabled": true, "threshold": 0.78}
  },
  "version": "1.0.0"
}
