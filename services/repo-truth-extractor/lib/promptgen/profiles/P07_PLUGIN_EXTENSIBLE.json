{
  "description": "Plugin-extensible system with dynamic registration or plugin roots.",
  "match_weights": {
    "is_plugin_system": 3.0,
    "is_monorepo": 0.8,
    "is_microservices": 0.5
  },
  "phase_policy": {
    "budgets_by_phase": {
      "C": {"file_truncate_chars": 65000, "max_chars": 560000, "max_files": 15}
    },
    "prompt_variants_by_phase_step": {
      "C": {"C0": "plugin_discovery", "C1": "plugin_discovery"}
    },
    "targets_by_phase": {
      "C": ["plugins", "services", "src", "shared", "scripts", "docs"]
    }
  },
  "priority": 76,
  "profile_id": "P07_PLUGIN_EXTENSIBLE",
  "prompt_overlays": {
    "base": "Bias extraction toward plugin registries, dynamic imports, and extension boundaries."
  },
  "selection_threshold": 1.6,
  "v2_rules": {
    "RULE_ENABLE_STRICT_ENVELOPE_ON_PARSE": {"enabled": true},
    "RULE_REDUCE_MAX_FILES_ON_PARSE_OR_EMPTY": {"decrement": 2, "enabled": true, "threshold": 1},
    "RULE_SHRINK_BUDGET_ON_PAYLOAD_UNSHRINKABLE": {"enabled": true, "factor": 0.78, "threshold": 1},
    "RULE_SPLIT_STEP_ON_MISSING_ARTIFACTS": {"enabled": true, "threshold": 0.3},
    "RULE_TARGET_REORDER_ON_THIN_COVERAGE": {"enabled": true, "threshold": 0.7}
  },
  "version": "1.0.0"
}
