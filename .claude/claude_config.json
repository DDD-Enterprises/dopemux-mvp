{
  "mcpServers": {
    "conport": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "-e",
        "DOPEMUX_INSTANCE_ID",
        "-e",
        "DOPEMUX_WORKSPACE_ID",
        "mcp-conport",
        "uvx",
        "--from",
        "context-portal-mcp",
        "conport-mcp"
      ],
      "env": {
        "DOPEMUX_INSTANCE_ID": "${DOPEMUX_INSTANCE_ID:-main}",
        "DOPEMUX_WORKSPACE_ID": "${DOPEMUX_WORKSPACE_ID:-.}"
      }
    },
    "gpt-researcher_wrapped": {
      "command": "python",
      "args": [
        "scripts/mcp/mcp_event_wrapper.py",
        "--server",
        "gpt-researcher",
        "--instance",
        "${DOPEMUX_INSTANCE_ID:-A}",
        "--redis-host",
        "localhost",
        "--redis-port",
        "6379"
      ],
      "env": {
        "WORKSPACE_PATH": ".",
        "EXA_API_KEY": "${EXA_API_KEY}",
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}",
        "DEBUG": "false",
        "DOPEMUX_INSTANCE_ID": "${DOPEMUX_INSTANCE_ID:-A}"
      },
      "type": "stdio"
    },
    "serena": {
      "command": "uvx",
      "args": [
        "mcp-proxy",
        "--transport",
        "streamablehttp",
        "http://127.0.0.1:3006/sse"
      ],
      "env": {},
      "type": "stdio"
    },
    "dope-context": {
      "command": "bash",
      "args": [
        "services/dope-context/run_mcp.sh"
      ],
      "env": {},
      "type": "stdio"
    },
    "mas-sequential-thinking": {
      "command": "docker",
      "args": [
        "exec",
        "mcp-mas-sequential-thinking",
        "mcp-server-mas-sequential-thinking"
      ],
      "env": {},
      "type": "stdio"
    },
    "zen": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/BeehiveInnovations/zen-mcp-server.git",
        "zen-mcp-server"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "GOOGLE_API_KEY": "${GEMINI_API_KEY}",
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "GROQ_API_KEY": "${GROQ_API_KEY}"
      },
      "type": "stdio"
    },
    "context7": {
      "command": "npx",
      "args": [
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "type": "stdio"
    },
    "gpt-researcher": {
      "command": "python",
      "args": [
        "docker/mcp-servers/gpt-researcher/scripts/mcp_server.py"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "VOYAGEAI_API_KEY": "${VOYAGEAI_API_KEY}",
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "type": "stdio"
    },
    "conport-admin": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-conport_main",
        "python",
        "/app/conport_mcp_stdio.py"
      ],
      "env": {
        "CONPORT_URL": "http://localhost:3005"
      }
    },
    "exa": {
      "command": "uvx",
      "args": [
        "mcp-proxy",
        "--transport",
        "streamablehttp",
        "http://127.0.0.1:3007/sse"
      ],
      "env": {},
      "type": "stdio"
    },
    "task-orchestrator": {
      "command": "python",
      "args": [
        "services/task-orchestrator/server.py"
      ],
      "env": {},
      "type": "stdio"
    }
  }
}
