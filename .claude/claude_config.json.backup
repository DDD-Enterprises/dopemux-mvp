{
  "mcpServers": {
    "conport": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-conport",
        "uvx",
        "--from",
        "context-portal-mcp",
        "conport-mcp"
      ],
      "env": {
        "DOPEMUX_INSTANCE_ID": "main",
        "DOPEMUX_WORKSPACE_ID": "/Users/hue/code/dopemux-mvp"
      }
    },
    "serena": {
      "command": "uvx",
      "args": [
        "mcp-proxy",
        "--transport",
        "streamablehttp",
        "http://127.0.0.1:3006/sse"
      ],
      "env": {},
      "type": "stdio"
    },
    "dope-context": {
      "command": "uvx",
      "args": [
        "mcp-proxy",
        "--transport",
        "streamablehttp",
        "http://127.0.0.1:3010/sse"
      ],
      "env": {},
      "type": "stdio"
    },
    "zen": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/BeehiveInnovations/zen-mcp-server.git",
        "zen-mcp-server"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}",
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "GROQ_API_KEY": "${GROQ_API_KEY}"
      },
      "type": "stdio"
    },
    "context7": {
      "command": "npx",
      "args": [
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "type": "stdio"
    },
    "gpt-researcher": {
      "command": "uvx",
      "args": [
        "mcp-proxy",
        "--transport",
        "sse",
        "http://127.0.0.1:3009/sse"
      ],
      "env": {},
      "type": "stdio"
    },
    "exa": {
      "command": "uvx",
      "args": [
        "mcp-proxy",
        "--transport",
        "streamablehttp",
        "http://127.0.0.1:3008/sse"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "type": "stdio"
    },
    "desktop-commander": {
      "command": "uvx",
      "args": [
        "mcp-proxy",
        "--transport",
        "streamablehttp",
        "http://127.0.0.1:3012/sse"
      ],
      "env": {
        "DISPLAY": "${DISPLAY:-:0}"
      },
      "type": "stdio"
    },
    "leantime-bridge": {
      "command": "uvx",
      "args": [
        "mcp-proxy",
        "--transport",
        "streamablehttp",
        "http://127.0.0.1:3015/sse"
      ],
      "env": {},
      "type": "stdio"
    },
    "task-orchestrator": {
      "command": "python",
      "args": [
        "services/task-orchestrator/server.py"
      ],
      "env": {},
      "type": "stdio"
    },
    "conport-admin": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-conport",
        "python",
        "/app/conport_mcp_stdio.py"
      ],
      "env": {
        "CONPORT_URL": "http://localhost:3004"
      }
    }
  }
}