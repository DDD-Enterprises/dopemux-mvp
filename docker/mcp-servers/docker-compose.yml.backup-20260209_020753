  # Desktop Commander - Desktop automation and system control
  desktop-commander:
    build:
      context: ./desktop-commander
      dockerfile: Dockerfile
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-mcp-desktop-commander"
    restart: unless-stopped
    networks:
      - dopemux-network
    environment:
      - MCP_SERVER_PORT=3012
      - DISPLAY=${DISPLAY:-:0}
    ports:
      - "3012:3012"
    volumes:
      - /tmp/.X11-unix:/tmp/.X11-unix:rw
      - /tmp:/tmp
    healthcheck:
      test: [ "CMD", "curl", "-f", "http://localhost:3012/health" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 45s
    labels:
      - "mcp.role=utility"
      - "mcp.priority=medium"
      - "mcp.description=Desktop automation and system control"

  # Activity Capture - Automatic development activity tracking for ADHD Engine
  # NOTE: ADHD Engine (port 8095) runs as background process via start-all.sh
  #       (Docker version has dependency issues - TODO: Fix in future)
  activity-capture:
    build:
      context: ../../services/activity-capture
      dockerfile: Dockerfile
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-activity-capture"
    restart: unless-stopped
    networks:
      - dopemux-network
    environment:
      - REDIS_URL=redis://redis-events:6379
      - STREAM_NAME=dopemux:events
      - CONSUMER_GROUP=activity-capture
      - CONSUMER_NAME=activity-capture-1
      - ADHD_ENGINE_URL=http://host.docker.internal:8095
      - ADHD_USER_ID=hue
      - AGGREGATION_WINDOW_SECONDS=300
      - API_PORT=8096
    ports:
      - "8096:8096"
    # depends_on removed - desktop-commander migrated to uvx
    healthcheck:
      test: [ "CMD-SHELL", "curl -f http://localhost:8096/health || exit 1" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 45s
    labels:
      - "mcp.role=adhd-support"
      - "mcp.priority=high"
      - "mcp.description=Automatic activity tracking for ADHD Engine"

  # Redis Primary - Shared cache for MCP servers (ConPort, etc.)
  redis-primary:
    image: redis:7-alpine
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-redis-primary"
    restart: unless-stopped
    networks:
      - dopemux-network
    command: redis-server --appendonly yes
    volumes:
      - mcp_redis_primary_data:/data
    healthcheck:
      test: [ "CMD", "redis-cli", "ping" ]
      timeout: 3s
      retries: 5
      interval: 10s
    labels:
      - "mcp.role=infrastructure"
      - "mcp.priority=high"
      - "mcp.description=Shared Redis cache for MCP servers"

  # Qdrant - Vector database for dope-context semantic search
  qdrant:
    image: qdrant/qdrant:latest
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-mcp-qdrant"
    restart: unless-stopped
    networks:
      - dopemux-network
    ports:
      - "6333:6333"
      - "6334:6334"
    volumes:
      - mcp_qdrant_data:/qdrant/storage
    healthcheck:
      # Use curl instead of wget (more commonly available)
      test: [ "CMD-SHELL", "curl -f http://localhost:6333/readyz || exit 1" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 30s
    labels:
      - "mcp.role=infrastructure"
      - "mcp.priority=high"
      - "mcp.description=Vector database for semantic code search"

# === NETWORKS ===
networks:
  dopemux-network:
    external: true
  mcp-network:
    external: true
    name: dopemux-network
  leantime-net:
    external: true
    name: leantime-net

# === VOLUMES ===
volumes:
  # Flexible Postgres AGE data volume; attach existing named volume via env
  pg_age_data:
    external: true
    name: ${POSTGRES_AGE_VOLUME:-mcp_postgres_age_data}
