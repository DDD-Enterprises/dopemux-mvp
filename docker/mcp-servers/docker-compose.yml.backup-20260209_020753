  # MCP Client - Custom client for stdio MCP servers
  mcp-client:
    build:
      context: ../../services/mcp-client
      dockerfile: Dockerfile
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-mcp-client"
    restart: unless-stopped
    networks:
      - dopemux-network
    environment:
      - OPENAI_API_KEY=sk-master-dopemux-local-20251101
      - OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
      - GEMINI_API_KEY=${GEMINI_API_KEY}
      - XAI_API_KEY=${XAI_API_KEY}
      - EXA_API_KEY=${EXA_API_KEY}
    volumes:
      - mcp_client_data:/app/data
      - mcp_client_logs:/app/logs
      - /var/run/docker.sock:/var/run/docker.sock
    labels:
      - "mcp.role=client"
      - "mcp.priority=high"
      - "mcp.description=Custom MCP client for stdio server integration"

  # ConPort - Knowledge Graph Dashboard & API
  conport:
    build:
      context: ../..
      dockerfile: services/conport/Dockerfile
    container_name: mcp-conport
    restart: unless-stopped
    networks:
      - dopemux-network
      - mcp-network
    environment:
      - MCP_SERVER_PORT=3004
      - POSTGRES_HOST=dopemux-postgres-age
      - POSTGRES_PORT=5432
      - POSTGRES_USER=dopemux_age
      - POSTGRES_PASSWORD=dopemux_age_dev_password
      - POSTGRES_DB=dopemux_knowledge_graph
      - LOG_LEVEL=INFO
    ports:
      - "3004:3004"
    volumes:
      - mcp_conport_logs:/app/logs
    healthcheck:
      test: [ "CMD", "curl", "-f", "http://localhost:3004/health" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 45s
    labels:
      - "mcp.role=dashboard"
      - "mcp.priority=high"
      - "mcp.description=Knowledge graph dashboard and API (Postgres backed)"

  # Task Orchestrator - Advanced task orchestration and dependency management
  task-orchestrator:
    build:
      context: ../../services/task-orchestrator
      dockerfile: Dockerfile
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-mcp-task-orchestrator"
    # Now always-on MCP server
    restart: unless-stopped
    networks:
      - dopemux-network
    env_file:
      - ./task-orchestrator/.env
    environment:
      - MCP_SERVER_PORT=8000
      - JVM_HEAP_SIZE=512m
      - REDIS_URL=redis://dopemux-redis-primary:6379
      - PAL_API_URL=http://host.docker.internal:3003
    ports:
      - "3014:8000"
    # depends_on: redis-primary (redis already running externally)
    # MCP server health check
    healthcheck:
      test: [ "CMD", "curl", "-f", "http://localhost:8000/health" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 45s
    volumes:
      - mcp_task_orchestrator_data:/app/data
      - mcp_task_orchestrator_logs:/app/logs
    # Run uvicorn server (uses Dockerfile CMD)
    # command defaults to: uvicorn app.main:app --host 0.0.0.0 --port 8000
    stdin_open: true
    tty: true
    labels:
      - "mcp.role=workflow"
      - "mcp.priority=high"
      - "mcp.description=Task orchestration and dependency management with 37 tools"
    extra_hosts:
      - "host.docker.internal:host-gateway"

  # Leantime Bridge - Connects existing Leantime to MCP network (HTTP/SSE transport)
  leantime-bridge:
    build:
      context: ./leantime-bridge
      dockerfile: Dockerfile
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-mcp-leantime-bridge"
    restart: unless-stopped
    networks:
      - dopemux-network
      - leantime-net
    env_file:
      - ./leantime-bridge/.env
    environment:
      - MCP_SERVER_HOST=0.0.0.0
      - MCP_SERVER_PORT=3015
      - LEANTIME_API_URL=${LEANTIME_API_URL:-${LEANTIME_URL:-http://leantime:80}}
      - LEANTIME_API_TOKEN=${LEANTIME_API_TOKEN:-${LEANTIME_TOKEN:-}}
      - LEAN_TIME_RATE_LIMIT_SECONDS=${LEAN_TIME_RATE_LIMIT_SECONDS:-1.0}
      - REDIS_URL=redis://dopemux-redis-primary:6379
    ports:
      - "3015:3015"
    depends_on:
      - redis-primary
    healthcheck:
      test: [ "CMD-SHELL", "curl -f http://localhost:3015/health || exit 1" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 45s
    volumes:
      - mcp_leantime_bridge_data:/app/data
      - mcp_leantime_bridge_logs:/app/logs
    labels:
      - "mcp.role=workflow"
      - "mcp.priority=high"
      - "mcp.transport=http-sse"
      - "mcp.description=Leantime project management integration bridge (HTTP/SSE)"

  # Plane Coordinator - Two-plane architecture coordination service
  plane-coordinator:
    build:
      context: ../../services/task-orchestrator
      dockerfile: Dockerfile.coordination
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-mcp-plane-coordinator"
    restart: unless-stopped
    networks:
      - dopemux-network
    environment:
      - COORDINATION_API_PORT=8090
      - MCP_SERVER_PORT=8090
      - PORT=8090
      - WORKSPACE_ID=${DOPEMUX_WORKSPACE_ID:-/workspace}
      - REDIS_URL=redis://dopemux-redis-primary:6379
      - CONPORT_URL=${CONPORT_URL:-http://conport:3004}
      - ADHD_ENGINE_URL=${ADHD_ENGINE_URL:-http://host.docker.internal:8095}
      - ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8097
    ports:
      - "8090:8090"
    depends_on:
      - redis-primary
    healthcheck:
      test: [ "CMD-SHELL", "curl -f http://localhost:8090/health || exit 1" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 30s
    volumes:
      - mcp_plane_coordinator_data:/app/data
      - mcp_plane_coordinator_logs:/app/logs
    labels:
      - "mcp.role=workflow"
      - "mcp.priority=high"
      - "mcp.transport=http"
      - "mcp.description=Two-plane architecture coordination between PM and Cognitive planes"

  # Serena - Code navigation, refactoring, LSP functionality
  serena:
    build:
      context: ./serena
      dockerfile: Dockerfile
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-mcp-serena${DOPEMUX_INSTANCE_ID:+_}${DOPEMUX_INSTANCE_ID}"
    restart: unless-stopped
    networks:
      - dopemux-network
    environment:
      - MCP_SERVER_PORT=${SERENA_PORT:-3006} # Dynamic port from instance env
      - WORKSPACE_ID=${DOPEMUX_WORKSPACE_ID} # CRITICAL: Instance workspace isolation
    ports:
      - "${SERENA_PORT:-3006}:${SERENA_PORT:-3006}" # Multi-instance port mapping
      - "4006:4006" # Info server for service discovery
    healthcheck:
      test: [ "CMD", "sh", "-c", "exit 0" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 10s
    volumes:
      - mcp_serena_data:/app/data
      - ${DOPEMUX_CODE_PARENT:-~/code}:/workspaces:ro # Mount parent to support all worktrees
    labels:
      - "mcp.role=workflow"
      - "mcp.priority=medium"
      - "mcp.description=Code navigation and refactoring with project access"

  # === RESEARCH SERVERS (Priority: Low - Fallback Only) ===

  # Dopemux GPT Researcher - ADHD-optimized research with enhanced features
  dopemux-gpt-researcher:
    build:
      context: ../../services/dopemux-gpt-researcher
      dockerfile: Dockerfile
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-gpt-researcher"
    restart: unless-stopped
    networks:
      - dopemux-network
    environment:
      - WORKSPACE_PATH=${DOPEMUX_WORKSPACE_ID:-/workspaces/dopemux-mvp} # Auto-detect from host
      - WORKSPACE_ID=${DOPEMUX_WORKSPACE_ID:-/workspaces/dopemux-mvp} # Backward compatibility
      - OPENAI_API_KEY=sk-master-dopemux-local-20251101
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
      - TAVILY_API_KEY=${TAVILY_API_KEY}
      - EXA_API_KEY=${EXA_API_KEY}
      - PERPLEXITY_API_KEY=${PERPLEXITY_API_KEY}
      - CONPORT_ENABLED=true
      - WEBSOCKET_PORT=8001
      - API_PORT=8000
    ports:
      - "8000:8000" # FastAPI backend
      - "8001:8001" # WebSocket progress streaming
    healthcheck:
      test: [ "CMD-SHELL", "curl -f http://localhost:8000/health || exit 1" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 45s
    volumes:
      - mcp_dopemux_gpt_data:/app/data
      - mcp_dopemux_gpt_logs:/app/logs
      - mcp_dopemux_gpt_cache:/app/cache
      - ${DOPEMUX_CODE_PARENT:-~/code}:/workspaces:ro # Mount parent to support all worktrees
    labels:
      - "mcp.role=research"
      - "mcp.priority=highest"
      - "mcp.description=ADHD-optimized research with real-time progress and pause/resume"

