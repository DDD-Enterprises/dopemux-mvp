  # Dope Context - Semantic code and document search
  dope-context:
    build:
      context: ../../services/dope-context
      dockerfile: Dockerfile
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-mcp-dope-context"
    restart: unless-stopped
    networks:
      - dopemux-network
    environment:
      - MCP_SERVER_PORT=3010
      - QDRANT_URL=mcp-qdrant
      - QDRANT_PORT=6333
      - VOYAGEAI_API_KEY=${VOYAGEAI_API_KEY}
      - VOYAGE_API_KEY=${VOYAGEAI_API_KEY}
      - OPENAI_API_KEY=sk-master-dopemux-local-20251101
      - WORKSPACE_ID=${DOPEMUX_WORKSPACE_ID}
      - DOPEMUX_WORKSPACE_ROOT=/workspaces/dopemux-mvp
      # CRITICAL: Hash override ensures collection names match between host and container
      # Host indexes with path /Users/hue/code/dopemux-mvp (hash=3ca12e07)
      # Container mounts as /workspaces/dopemux-mvp (different hash)
      # Override ensures both use same collection name in Qdrant
      - WORKSPACE_HASH_OVERRIDE=3ca12e07
    ports:
      - "3010:3010"
    depends_on:
      - qdrant
    healthcheck:
      # Check actual health endpoint instead of process
      test: [ "CMD-SHELL", "curl -f http://localhost:3010/health || exit 1" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 45s
    volumes:
      - dope_context_data:/app/data
      - dope_context_logs:/app/logs
      - ${DOPEMUX_CODE_PARENT:-~/code}:/workspaces:ro
    labels:
      - "mcp.role=search"
      - "mcp.priority=high"
      - "mcp.description=Semantic code and document search with AST-aware indexing"

