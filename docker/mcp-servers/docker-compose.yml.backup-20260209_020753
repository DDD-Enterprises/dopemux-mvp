  #     - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
  #     - OPENAI_API_KEY=sk-master-dopemux-local-20251101
  #     - GOOGLE_API_KEY=${GOOGLE_API_KEY}
  #     - PERPLEXITY_API_KEY=${PERPLEXITY_API_KEY}
  #   # stdio transport does not expose HTTP; container stays idle until mcp-client execs the server
