  litellm:
    build:
      context: ../../
      dockerfile: docker/mcp-servers/litellm/Dockerfile
    container_name: "${DOPEMUX_STACK_PREFIX:-dopemux}-mcp-litellm"
    restart: unless-stopped
    networks:
      - dopemux-network
    ports:
      - "4000:4000"
    environment:
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
      - OPENAI_API_KEY=sk-master-dopemux-local-20251101
      - XAI_API_KEY=${XAI_API_KEY}
      - OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
      - GEMINI_API_KEY=${GEMINI_API_KEY}
      - LITELLM_MASTER_KEY=${LITELLM_MASTER_KEY:-sk-master-dopemux-local-20251101}
      - DATABASE_URL=postgresql://dopemux_age:dopemux_age_dev_password@dopemux-postgres-age:5432/litellm
      - LITELLM_LOG=INFO
      - LITELLM_DROP_PARAMS=true
    healthcheck:
      test: [ "CMD", "curl", "-sf", "http://localhost:4000/health" ]
      timeout: 10s
      retries: 3
      interval: 30s
      start_period: 60s
    volumes:
      - ../../litellm.config.yaml:/app/config.yaml:ro
      - mcp_litellm_data:/app/data
    labels:
      - "mcp.role=critical_path"
      - "mcp.priority=high"
      - "mcp.description=Unified LLM proxy with intelligent routing and cost tracking"

  # === WORKFLOW SERVERS (Priority: Medium) ===
