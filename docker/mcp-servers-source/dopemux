#!/bin/bash

# Dopemux wrapper - delegates to the Python CLI
# This script exists to maintain compatibility with existing workflows
# but all functionality is now handled by the Python CLI

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Delegate to the Python CLI
exec python3 -m dopemux.cli "$@"
