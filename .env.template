# Dopemux Environment Template
# Copy this to .env and fill in your keys

# --- API KEYS ---
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...
VOYAGE_API_KEY=pa-...
XAI_API_KEY=xai-...
OPENAI_API_KEY=sk-...

# --- MULTI-INSTANCE PORTS (Optional overrides) ---
# Default base is 3000. Each instance adds +30.
DOPEMUX_PORT_BASE=3000

# Service Port Offsets:
# DOPECON_BRIDGE: +0 (3016 default for Instance A)
# PAL: +3 (3003)
# CONPORT_HTTP: +4 (3004)
# CONPORT_MCP: +5 (3005)
# SERENA: +6 (3006)
# GPT_RESEARCHER: +9 (3009)
# DOPE_CONTEXT: +10 (3010)
# EXA: +11 (3011)
# DESKTOP_COMMANDER: +12 (3012)
# TASK_ORCHESTRATOR: +14 (3014)
# LEANTIME_BRIDGE: +15 (3015)
# DOPE_MEMORY: +20 (3020)
# ADHD_ENGINE: +25 (3025)

# --- INFRASTRUCTURE ---
POSTGRES_PASSWORD=dopemux_age_dev_password
AGE_PASSWORD=dopemux_age_dev_password
REDIS_URL=redis://redis-primary:6379

# --- LEANTIME ---
LEANTIME_URL=http://localhost:8080
LEANTIME_TOKEN=your-leantime-token
