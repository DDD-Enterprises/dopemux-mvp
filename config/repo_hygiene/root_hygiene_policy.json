{
  "version": 1,
  "allowed_root_dirs": [
    ".taskx",
    ".claude",
    ".githooks",
    ".github",
    "SYSTEM_ARCHIVE",
    "components",
    "compose",
    "config",
    "dashboard",
    "docker",
    "docs",
    "examples",
    "extraction",
    "installers",
    "interruption_shield",
    "logs",
    "plugins",
    "profiles",
    "quarantine",
    "out",
    "reports",
    "scripts",
    "services",
    "shared",
    "src",
    "tests",
    "tmp",
    "tools",
    "ui-dashboard",
    "ui-dashboard-backend"
  ],
  "allowed_root_files": [
    ".taskxroot",
    ".taskx-pin",
    ".repo_id",
    ".backup_location",
    ".claude.json",
    ".claude.json.template",
    ".dockerignore",
    ".env.example",
    ".gitignore",
    ".lychee.toml",
    ".markdownlint.jsonc",
    ".pre-commit-config.yaml",
    ".tmux.conf",
    "AGENTS.md",
    "CHANGELOG.md",
    "INSTALL.md",
    "Makefile",
    "QUICK_START.md",
    "README.md",
    "compose.yml",
    "docker-compose*.yml",
    "litellm.config",
    "litellm.config.yaml",
    "mcp-proxy-config*.yaml",
    "mcp-proxy-config.json",
    "package.json",
    "pyproject.toml",
    "MANIFEST.in",
    "pytest.ini",
    "requirements*.txt",
    "dopemux.rb",
    "dopemux.toml",
    "install.sh",
    "mcp_server_health_report.sh",
    "run_all_multi_workspace_tests.sh",
    "start-mcp-servers.sh",
    "test_installer_basic.sh",
    "test_installer_ubuntu.sh",
    "verify_dopecon_bridge.sh",
    "tmux-dopemux-orchestrator.yaml"
  ],
  "legacy_root_files": [],
  "blocked_root_file_patterns": [
    "*_REPORT.md",
    "*_STATUS.md",
    "*_PLAN.md",
    "coverage.xml",
    "*.zip",
    "*.tar",
    "*.tar.gz",
    "*.tgz",
    "*.log",
    "conport_backup_*.json",
    "deleted_docs_list.txt",
    "SESSION_*.md",
    "THREAD_WORK_SUMMARY.md",
    "*_test_results.json",
    "*_validation_results.json",
    "*_layer*_*.json"
  ],
  "blocked_root_dir_patterns": [
    "htmlcov",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache",
    ".venv",
    ".taskx_venv",
    ".sessions",
    "node_modules"
  ],
  "destination_hints": [
    {
      "patterns": [
        "*_REPORT.md",
        "*_STATUS.md",
        "*_PLAN.md",
        "*_PROGRESS.md"
      ],
      "destination": "docs/05-audit-reports/",
      "purpose": "durable human-readable reports"
    },
    {
      "patterns": [
        "*.json",
        "*.xml",
        "*.zip",
        "*.tar",
        "*.tar.gz",
        "*.tgz"
      ],
      "destination": "reports/",
      "purpose": "generated machine outputs and bundles"
    },
    {
      "patterns": [
        "*.log"
      ],
      "destination": "logs/",
      "purpose": "runtime logs"
    },
    {
      "patterns": [
        "*.py",
        "*.sh",
        "*.rb"
      ],
      "destination": "scripts/",
      "purpose": "reusable automation scripts"
    },
    {
      "patterns": [
        "*.sql"
      ],
      "destination": "scripts/sql/",
      "purpose": "SQL migrations or utility queries"
    },
    {
      "patterns": [
        "*.md"
      ],
      "destination": "docs/",
      "purpose": "project documentation"
    }
  ]
}