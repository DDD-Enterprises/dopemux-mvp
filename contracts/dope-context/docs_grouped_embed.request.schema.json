{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dope-context/docs_grouped_embed.request.schema.json",
  "type": "object",
  "required": [
    "model",
    "documents"
  ],
  "properties": {
    "model": {
      "type": "string",
      "const": "voyage-context-3"
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "doc_id",
          "source_uri",
          "chunks"
        ],
        "properties": {
          "doc_id": {
            "type": "string",
            "minLength": 1
          },
          "source_uri": {
            "type": "string",
            "minLength": 1
          },
          "chunks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "chunk_id",
                "ordinal",
                "text"
              ],
              "properties": {
                "chunk_id": {
                  "type": "string",
                  "minLength": 1
                },
                "ordinal": {
                  "type": "integer",
                  "minimum": 0
                },
                "text": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
