#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TASKX_BIN="$REPO_ROOT/.venv-taskx/bin/taskx"

if [[ ! -x "$TASKX_BIN" ]]; then
  echo "ERROR: repo-local TaskX not found at: $TASKX_BIN" >&2
  echo "Fix: create the venv and install TaskX:" >&2
  echo "  python -m venv .venv-taskx && source .venv-taskx/bin/activate && pip install -e /Users/hue/code/taskX" >&2
  exit 2
fi

exec "$TASKX_BIN" "$@"
