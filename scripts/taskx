#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
EXPECTED_PROJECT_ID="dopemux-mvp"

if [[ ! -f "$REPO_ROOT/.taskxroot" ]]; then
  echo "Refusing: .taskxroot missing in repo root: $REPO_ROOT" >&2
  exit 2
fi

if [[ ! -f "$REPO_ROOT/.repo_id" ]]; then
  echo "Refusing: .repo_id missing in repo root: $REPO_ROOT" >&2
  exit 2
fi

REPO_PROJECT_ID="$(sed -n 's/^project=//p' "$REPO_ROOT/.repo_id" | head -n 1)"
if [[ "$REPO_PROJECT_ID" != "$EXPECTED_PROJECT_ID" ]]; then
  echo "Refusing: wrong repo_id project. expected=$EXPECTED_PROJECT_ID got=${REPO_PROJECT_ID:-<missing>}" >&2
  exit 2
fi

if [[ ! -f "$REPO_ROOT/.taskx/project.json" ]]; then
  echo "Refusing: .taskx/project.json missing in repo root." >&2
  exit 2
fi

TASKX_PROJECT_ID="$(python3 - "$REPO_ROOT/.taskx/project.json" <<'PY'
import json
import sys

path = sys.argv[1]
try:
    with open(path, "r", encoding="utf-8") as fh:
        payload = json.load(fh)
except Exception:
    print("")
    raise SystemExit(0)

print(str(payload.get("project_id", "")).strip())
PY
)"
if [[ "$TASKX_PROJECT_ID" != "$EXPECTED_PROJECT_ID" ]]; then
  echo "Refusing: .taskx/project.json project_id mismatch. expected=$EXPECTED_PROJECT_ID got=${TASKX_PROJECT_ID:-<missing>}" >&2
  exit 2
fi

TASKX_SOURCE_DIR="$REPO_ROOT/vendor/taskx"
if [[ ! -d "$TASKX_SOURCE_DIR" ]]; then
  echo "Refusing: TaskX submodule missing at $TASKX_SOURCE_DIR" >&2
  echo "Run: git submodule update --init --recursive vendor/taskx" >&2
  exit 2
fi
if [[ ! -f "$TASKX_SOURCE_DIR/pyproject.toml" ]]; then
  echo "Refusing: invalid TaskX submodule; pyproject.toml missing at $TASKX_SOURCE_DIR" >&2
  exit 2
fi

TASKX_COMMIT="$(git -C "$TASKX_SOURCE_DIR" rev-parse HEAD 2>/dev/null || true)"
if [[ -z "$TASKX_COMMIT" ]]; then
  echo "Refusing: unable to resolve TaskX submodule commit at $TASKX_SOURCE_DIR" >&2
  exit 2
fi

VENV="$REPO_ROOT/.taskx_venv"
if [[ ! -d "$VENV" ]]; then
  python3 -m venv "$VENV"
fi

TASKX_COMMIT_FILE="$VENV/.taskx_submodule_commit"
INSTALLED_COMMIT=""
if [[ -f "$TASKX_COMMIT_FILE" ]]; then
  INSTALLED_COMMIT="$(cat "$TASKX_COMMIT_FILE" 2>/dev/null || true)"
fi

ensure_taskx_installed() {
  source "$VENV/bin/activate"
  pip install --quiet --upgrade pip
  pip install --quiet --upgrade -e "$TASKX_SOURCE_DIR[dopemux]"
  printf '%s\n' "$TASKX_COMMIT" > "$TASKX_COMMIT_FILE"
}

if [[ ! -x "$VENV/bin/taskx" || "$INSTALLED_COMMIT" != "$TASKX_COMMIT" ]]; then
  ensure_taskx_installed
else
  source "$VENV/bin/activate"
fi

exec "$VENV/bin/taskx" "$@"
