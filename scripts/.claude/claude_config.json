{
  "mcpServers": {
    "conport": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-conport_main",
        "uvx",
        "--from",
        "context-portal-mcp",
        "conport-mcp"
      ],
      "env": {
        "DOPEMUX_INSTANCE_ID": "main",
        "DOPEMUX_WORKSPACE_ID": "/Users/hue/code/dopemux-mvp"
      }
    },
    "conport-admin": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-conport_main",
        "python",
        "/app/conport_mcp_stdio.py"
      ],
      "env": {
        "CONPORT_URL": "http://localhost:3005"
      }
    }
  }
}